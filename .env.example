# Signs and encrypts the access cookie. Generate one with: openssl rand -hex 32
# Required in production. Falls back to an insecure dev default if left unset.
SENTOU_SECRET=

# Where the file store keeps its JSON database.
SENTOU_DB=.sentou/db.json

# Public base URL used to build the links Sentou hands out.
SENTOU_BASE_URL=http://localhost:3000

# Base URL the MCP server publishes to when run from a Claude session.
SENTOU_URL=http://localhost:3000

# Optional. When set, the owner + stats endpoints require
# Authorization: Bearer <token>. Leave unset for single-tenant / local use.
# Set it for any internet-exposed deploy.
# SENTOU_OWNER_TOKEN=

# Optional email sender for link verification. Set both to turn the email gate
# on a link published with verifyEmail:true into a real boundary: a one-time
# code is emailed and access is granted only once the recipient enters it.
# SENTOU_RESEND_KEY is a Resend API key; SENTOU_EMAIL_FROM is the verified
# from-address (e.g. "Sentou <no-reply@yourdomain.com>"). Leave both unset and
# the code is logged to the server console instead (local testing, not a boundary).
# SENTOU_RESEND_KEY=
# SENTOU_EMAIL_FROM=
