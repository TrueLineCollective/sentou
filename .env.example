# Signs and encrypts access cookies, and seeds Better Auth's secret (set BETTER_AUTH_SECRET to
# override). Generate one with: openssl rand -hex 32
# Required in production (the app throws on the first request that needs it until set).
# Left unset outside production, a random per-process key is used (dev cookies reset on restart).
SENTOU_SECRET=

# SQLite database file (one file, no DB server). Holds links, viewers, tracking events, and user
# accounts as plaintext at rest: protect this file (permissions + disk encryption when exposed).
SENTOU_DB=.sentou/sentou.db

# Public base URL used to build the links Sentou hands out.
SENTOU_BASE_URL=http://localhost:3000

# Better Auth's base URL (sessions, invite links, redirects). Falls back to SENTOU_BASE_URL.
# Set this on any exposed deploy.
# BETTER_AUTH_URL=https://sentou.yourdomain.com

# Base URL the MCP server publishes to when run from a Claude session.
SENTOU_URL=http://localhost:3000

# Owner endpoints (publish, republish, revoke, stats, forget, keys) require authentication:
# a logged-in Better Auth session, or Authorization: Bearer <key> with a per-user API key.
# There is no shared owner token. The first account to sign up becomes the owner; further
# accounts require an invitation. Mint a key after signing in via POST /api/keys (returned once).
# Put the returned key here so the MCP server / automation can authenticate as you:
# SENTOU_API_KEY=

# Optional email sender (used for verifyEmail one-time codes AND member invitations). Set both:
# SENTOU_RESEND_KEY is a Resend API key; SENTOU_EMAIL_FROM is the verified from-address
# (e.g. "Sentou <no-reply@yourdomain.com>"). In production, a verifyEmail link or an invitation
# with no sender configured is rejected; in local dev the code/link is logged to the server console.
# SENTOU_RESEND_KEY=
# SENTOU_EMAIL_FROM=

# Optional. Prune stored viewer rows and tracking events older than this many days.
# SENTOU_RETENTION_DAYS=
