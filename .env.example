# Signs and encrypts the access cookie. Generate one with: openssl rand -hex 32
# Required in production (the app throws on the first request that needs it until set).
# Left unset outside production, a random per-process key is used (dev cookies reset on restart).
SENTOU_SECRET=

# Where the file store keeps its JSON database (plaintext personal data: protect this file).
SENTOU_DB=.sentou/db.json

# Public base URL used to build the links Sentou hands out.
SENTOU_BASE_URL=http://localhost:3000

# Base URL the MCP server publishes to when run from a Claude session.
SENTOU_URL=http://localhost:3000

# Gates the owner + stats endpoints (publish, republish, revoke, stats, forget) behind
# Authorization: Bearer <token>. REQUIRED in production and whenever SENTOU_BASE_URL is a
# non-localhost host (the app fails closed without it there). Optional only for a purely local instance.
# SENTOU_OWNER_TOKEN=

# Optional email sender for link verification. Set both to turn the email gate on a link
# published with verifyEmail:true into a real boundary: a one-time code is emailed and access
# is granted only once the recipient enters it. SENTOU_RESEND_KEY is a Resend API key;
# SENTOU_EMAIL_FROM is the verified from-address (e.g. "Sentou <no-reply@yourdomain.com>").
# In production a verifyEmail link with no sender is rejected; in local dev the code is logged
# to the server console as a testing fallback (never expose that instance).
# SENTOU_RESEND_KEY=
# SENTOU_EMAIL_FROM=

# Optional. Prune stored viewer rows and tracking events older than this many days.
# SENTOU_RETENTION_DAYS=
